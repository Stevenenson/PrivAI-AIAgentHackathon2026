LLM_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-3.1-pro-preview
GEMINI_VISION_MODEL=gemini-3.1-pro-preview
GEMINI_THINKING_LEVEL=high

# Optional comma-separated picker values shown in the web app.
GEMINI_MODELS=gemini-3.1-pro-preview,gemini-3-flash-preview,gemini-3.1-flash-lite

# Agent terminal tools. Leave WORKSPACE_ROOT empty until the user selects a folder.
WORKSPACE_ROOT=
TERMINAL_ENABLED=true
TERMINAL_TIMEOUT_S=60
TERMINAL_MAX_OUTPUT_CHARS=20000
TERMINAL_ALLOW_DANGEROUS=false
