LLM_PROVIDER=openai
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-5.4-mini
OPENAI_VISION_MODEL=gpt-5.4-mini
OPENAI_REASONING_EFFORT=low

# Optional comma-separated picker values shown in the web app.
OPENAI_MODELS=gpt-5.4-mini,gpt-5.4-nano,gpt-5.5,gpt-5-mini,gpt-5-nano

# Agent terminal tools. WORKSPACE_ROOT defaults to this repo.
TERMINAL_ENABLED=true
TERMINAL_TIMEOUT_S=60
TERMINAL_MAX_OUTPUT_CHARS=20000
TERMINAL_ALLOW_DANGEROUS=false
