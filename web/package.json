{
  "name": "privai",
  "version": "0.1.0",
  "private": true,
  "description": "Privai desktop AI workspace for business automation, documents, and app building",
  "author": "Privai",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:standalone": "next build && node electron/prepare-standalone.cjs",
    "build:backend": "cd .. && bash scripts/build_backend_binary.sh",
    "prepare:icons": "node electron/generate-icons.cjs",
    "desktop:dev": "electron .",
    "desktop:pack": "npm run prepare:icons && npm run build:standalone && electron-builder --dir",
    "dist": "npm run prepare:icons && npm run build:backend && npm run build:standalone && electron-builder",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "clsx": "^2.1.1",
    "firebase": "^12.13.0",
    "lucide-react": "^1.14.0",
    "monaco-editor": "^0.55.1",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-firebase-hooks": "^5.1.1",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "build": {
    "appId": "ro.privai.desktop",
    "productName": "Privai",
    "asar": true,
    "asarUnpack": [
      ".next/standalone/**/*"
    ],
    "files": [
      "electron/**/*",
      ".next/standalone/**/*",
      ".next/static/**/*",
      "public/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../dist-backend",
        "to": "backend",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.icns",
      "identity": null,
      "target": [
        "dmg",
        "zip"
      ]
    },
    "dmg": {
      "title": "Privai",
      "backgroundColor": "#0b0d12",
      "window": {
        "width": 540,
        "height": 380
      },
      "iconSize": 96
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "icon": "build/icon.png",
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Office"
    }
  }
}
