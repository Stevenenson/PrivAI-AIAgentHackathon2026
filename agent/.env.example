# Path to your Firebase service-account JSON.
# Firebase console → Project settings → Service accounts → Generate new private key.
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# Optional: pre-set owner UID. Leave blank to auto-discover from the backend's
# /pair/status endpoint after the user pairs through the web app.
OWNER_UID=

# The local FastAPI backend (this agent talks to it for /health and /admin/llm/*).
BACKEND_URL=http://127.0.0.1:8080

# The URL the web app should use to reach this device. For laptop dev this
# typically equals BACKEND_URL. On a real board you'd set this to the LAN URL,
# Tailscale magic-DNS, or Cloudflare-Tunnel hostname so the web app can reach it.
PUBLIC_BOARD_URL=http://127.0.0.1:8080

# Heartbeat cadence in ms.
HEARTBEAT_MS=10000

# Free-form label shown in the device card.
AGENT_VERSION=licenta-prototype-0.2
